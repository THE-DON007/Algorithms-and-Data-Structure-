#include <iostream>
using namespace std;

//function to check if a number is prime
bool isPrime(int num){
    if(num <= 1)
        return false;
    for(int i = 2; i < num; i++){
        if(num % i == 0)
            return false;
    }
    return true;
}

//function to print primes from 1 to n
void printPrimes(int n){
    cout<<"Prime numbers from 1 to " << n << " are:" << endl;

    for(int i = 1; i <= n; i++){
        if (isPrime(i)){
            cout<<i<< " "<<endl
;
        }
    }
}

int main(){
    int n;
    cout<<"Enter a number: "<<endl;
    cin>>n;
    printPrimes(n);
    return 0;
}
