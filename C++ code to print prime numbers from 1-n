#include <iostream>
using namespace std;

int checkPrime(int n) {
    if (n <= 1)
        return 0;

    for (int i = 2; i < n; i++) {
        if (n % i == 0)
            return 0;
    }
    return 1;
}

void displayPrimes(int n) {
    for (int i = 1; i <= n; i++) {
        if (checkPrime(i) == 1) {
            cout << i << " ";
        }
    }
}

int main() {
    int num;

    cout << "Enter number: ";
    cin >> num;

    cout << "Prime numbers are: ";
    displayPrimes(num);

    return 0;
}
